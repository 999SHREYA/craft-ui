// tsconfig.base.json (root)
{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "esModuleInterop":  true,
    "skipLibCheck":     true
  }
}